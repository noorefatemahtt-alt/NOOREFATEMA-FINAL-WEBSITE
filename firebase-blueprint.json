{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user account information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string", "description": "Full name of the user" },
        "email": { "type": "string", "format": "email", "description": "User email address" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "User access level" }
      },
      "required": ["uid", "name", "email", "createdAt", "role"]
    },
    "Booking": {
      "title": "Booking",
      "description": "Stores flight booking details",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the user who made the booking" },
        "flightDetails": { "type": "object", "description": "Details of the selected flight" },
        "passengerDetails": { "type": "object", "description": "Details of the passenger" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"], "description": "Current status of the booking" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Booking timestamp" }
      },
      "required": ["userId", "flightDetails", "passengerDetails", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Collection of user profiles"
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Collection of flight bookings"
    }
  }
}
